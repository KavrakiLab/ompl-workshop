-    return None
+    # State space
+    space = ob.RealVectorStateSpace(2)
+
+    bounds = ob.RealVectorBounds(2)
+    bounds.setLow(0)
+    bounds.setHigh(0, img_env.width)
+    bounds.setHigh(1, img_env.height)
+    space.setBounds(bounds)
+
+    # Space information
+    si = ob.SpaceInformation(space)
+    si.setStateValidityChecker(
+        partial(is_valid, img_env)
+    )
+    si.setStateValidityCheckingResolution(0.002)
+    si.setup()
+
+    # Start / goal
+    start_state = space.allocState()
+    start_state[0] = start[0]
+    start_state[1] = start[1]
+
+    goal_state = space.allocState()
+    goal_state[0] = goal[0]
+    goal_state[1] = goal[1]
+
+    # Problem
+    pdef = ob.ProblemDefinition(si)
+    pdef.setStartAndGoalStates(start_state, goal_state)
+
+    # Planner
+    planner = og.RRTConnect(si)
+    planner.setProblemDefinition(pdef)
+    planner.setup()
+
+    solved = planner.solve(2.0)
+
+    if not solved:
+        print("No solution found")
+        return None
+
+    path = pdef.getSolutionPath()
+    path.interpolate()
+
+    # Extract path
+    xs, ys = [], []
+    for i in range(path.getStateCount()):
+        s = path.getState(i)
+        xs.append(s[0])
+        ys.append(s[1])
+
+    return (xs, ys)
 
 
