 # ----------------------------
+# Validity checker
+# ----------------------------
+def is_valid(map_obj, state):
+    return map_obj.is_free(state[0], state[1])
+
+
+# ----------------------------
 # Planning
 # ----------------------------
 def plan(img_env, start, goal):
-    # TODO Return path
